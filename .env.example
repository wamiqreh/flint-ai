# ============================================================
# Flint — Environment Variables
# ============================================================
# Copy to .env:  cp .env.example .env
# ============================================================

# ---------- AI Providers ----------
OPENAI_API_KEY=                     # Required for OpenAI adapter

# ---------- Server ----------
# REDIS_URL=redis://localhost:6379  # Uncomment for production queue
# POSTGRES_URL=postgresql://flint:flint@localhost:5432/flint  # Uncomment for production store
WORKER_COUNT=4
LOG_LEVEL=INFO
CONCURRENCY_openai=5

# ---------- Security ----------
# ORCHESTRATOR_API_KEY=changeme    # Uncomment to protect API endpoints

# ---------- Monitoring (optional) ----------
# PROMETHEUS_PORT=9090
# GRAFANA_PORT=3000
