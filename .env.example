# ============================================================
# Flint — Environment Variables
# ============================================================
# Copy to .env and fill in the values:
#   cp .env.example .env
#
# Used by: docker-compose.prod.yml, docker-compose.monitoring.yml
# ============================================================

# ---------- PostgreSQL ----------
POSTGRES_USER=orchestrator
POSTGRES_PASSWORD=changeme          # REQUIRED — set a strong password
POSTGRES_DB=orchestrator

# ---------- Redis ----------
REDIS_CONSUMER_GROUP=flint-group
REDIS_RECLAIM_MIN_IDLE_MS=60000     # ms before reclaiming idle messages
REDIS_MAXMEMORY=256mb               # Redis memory limit

# ---------- Orchestrator API ----------
ORCHESTRATOR_API_KEY=changeme       # REQUIRED — protects all API endpoints
API_PORT=5156                       # Host port for the API

# ---------- OpenTelemetry (optional) ----------
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317

# ---------- Monitoring (optional) ----------
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=admin        # Grafana admin password (anonymous auth is on by default)
