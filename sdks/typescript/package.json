{
  "name": "@flintai/sdk",
  "version": "0.1.0",
  "description": "Flint — TypeScript SDK for queue-driven AI agent orchestration",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/esm/index.d.ts"
    },
    "./adapters": {
      "import": "./dist/esm/adapters/index.js",
      "require": "./dist/cjs/adapters/index.js",
      "types": "./dist/esm/adapters/index.d.ts"
    },
    "./adapters/vercel-ai": {
      "import": "./dist/esm/adapters/vercel-ai.js",
      "require": "./dist/cjs/adapters/vercel-ai.js",
      "types": "./dist/esm/adapters/vercel-ai.d.ts"
    },
    "./adapters/express": {
      "import": "./dist/esm/adapters/express.js",
      "require": "./dist/cjs/adapters/express.js",
      "types": "./dist/esm/adapters/express.d.ts"
    },
    "./adapters/nextjs": {
      "import": "./dist/esm/adapters/nextjs.js",
      "require": "./dist/cjs/adapters/nextjs.js",
      "types": "./dist/esm/adapters/nextjs.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.cjs.json",
    "build:esm": "tsc -p tsconfig.json",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "flint",
    "flintai",
    "agent",
    "orchestrator",
    "queue",
    "workflow",
    "sdk"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  }
}
